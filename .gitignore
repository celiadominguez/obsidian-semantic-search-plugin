# Dependencies
node_modules/

# Build artifact (produced by `npm run build`)
main.js
main.js.map

# Environment / secrets
.env

# Eval output (regenerated by `npm run eval`)
eval/results/

# One-time provenance inputs for the demo vault (not needed by a clone — the
# generated demo-vault/ notes and eval/*.jsonl assets are committed)
scripts/data/

# Obsidian workspace state inside the demo vault
demo-vault/.obsidian/

# OS noise
.DS_Store
